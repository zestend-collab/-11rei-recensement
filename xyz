const SECTION_LABELS = {
  bio:"Biographie", etatCivil:"État civil", naturalise:"Naturalisation",
  situationMilitaire:"Situation militaire", campagne:"Campagne 1939–40",
  captivite:"Captivité", mort:"Mort au combat", apres40:"Après juin 1940",
  citations:"Citations", presse:"Presse", justice:"Justice"
};
const SECTION_ORDER = ["bio","etatCivil","naturalise","situationMilitaire","campagne","mort","captivite","apres40","citations","presse","justice"];
const BADGE_LABELS = {mort:"Mort pour la France", evade:"Évadé", naturalise:"Naturalisé", doublon:"Doublon possible"};

function renderSection(key, value){
  if(!value) return "";
  const label = SECTION_LABELS[key];
  let body;
  if(typeof value === "string"){
    body = `<p>${value}</p>`;
  } else {
    body = `<ul>${value.map(v=>`<li>${v}</li>`).join("")}</ul>`;
  }
  return `<div class="sec ${key}"><div class="label">${label}</div><div class="body">${body}</div></div>`;
}

function cardHTML(entry, index){
  const stamps = (entry.badges||[]).map(b=>`<span class="stamp ${b}">${BADGE_LABELS[b]}</span>`).join("");
  const nameHTML = entry.link
    ? `<a href="${entry.link}" target="_blank" rel="noopener">${entry.name}</a>`
    : entry.name;
  let sections = "";
  if(entry.note){
    sections += `<div class="sec doublon"><div class="label">À vérifier</div><div class="body"><p>${entry.note}</p></div></div>`;
  }
  SECTION_ORDER.forEach(k=>{ sections += renderSection(k, entry[k]); });

  return `
  <article class="card" data-search="${(entry.name+' '+(entry.alt||'')+' '+(entry.birth||'')+' '+JSON.stringify(entry)).toLowerCase().replace(/"/g,'&quot;')}">
    <span class="tab">${entry.name.charAt(0)}</span>
    <div class="card-head">
      <div>
        <div class="card-num">N° ${String(index+1).padStart(3,'0')}</div>
        <div class="name">${nameHTML}</div>
        ${entry.alt ? `<div class="alt">${entry.alt}</div>` : ""}
        ${entry.birth ? `<div class="birth">${entry.birth}</div>` : ""}
      </div>
      <div class="stamps">${stamps}</div>
    </div>
    <div class="sections">${sections}</div>
    ${entry.sources && entry.sources.length ? `<div class="sources"><span class="label">Sources</span>${entry.sources.join(" · ")}</div>` : ""}
  </article>`;
}

const main = document.getElementById("main");
const empty = document.getElementById("empty");
main.insertAdjacentHTML("afterbegin", DATA.map(cardHTML).join(""));
main.appendChild(empty);

document.getElementById("count").textContent = DATA.length + " fiches";

// alphabet nav
const letters = [...new Set(DATA.map(d=>d.name.charAt(0)))].sort();
const alphaNav = document.getElementById("alphaNav");
"ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("").forEach(L=>{
  const has = letters.includes(L);
  const chip = document.createElement("span");
  chip.className = "alpha-chip" + (has ? "" : " dim");
  chip.textContent = L;
  if(has){
    chip.addEventListener("click", ()=>{
      const cards = [...document.querySelectorAll(".card")];
      const target = cards.find(c => c.querySelector(".name").textContent.trim().charAt(0) === L);
      if(target) target.scrollIntoView({behavior:"smooth", block:"start"});
    });
  }
  alphaNav.appendChild(chip);
});

// search
const search = document.getElementById("search");
search.addEventListener("input", ()=>{
  const q = search.value.trim().toLowerCase();
  const cards = document.querySelectorAll(".card");
  let visible = 0;
  cards.forEach(c=>{
    const match = c.dataset.search.includes(q);
    c.style.display = match ? "" : "none";
    if(match) visible++;
  });
  document.getElementById("count").textContent = visible + " / " + DATA.length + " fiches";
  empty.style.display = visible === 0 ? "block" : "none";
});

// back to top
const topBtn = document.getElementById("topBtn");
window.addEventListener("scroll", ()=>{
  topBtn.classList.toggle("show", window.scrollY > 700);
});
topBtn.addEventListener("click", ()=> window.scrollTo({top:0, behavior:"smooth"}));
</script>
