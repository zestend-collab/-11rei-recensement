<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Recensement 11e REI — X · Y · Z</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --paper:#EDEDEB;
  --paper-card:#FAFAF9;
  --ink:#2E2E2C;
  --ink-soft:#6B6B67;
  --ink-faint:#9B9B96;
  --rule:#D2D2CE;
  --rule-soft:#E2E2DF;
  --khaki:#2C5479;
  --khaki-soft:#5C7C9A;
  --red:#C1611B;
  --blue:#2C5479;
  --amber:#6B6B67;
  --shadow: 0 1px 0 rgba(30,30,28,.05), 0 8px 20px -14px rgba(30,30,28,.30);
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  background:
    radial-gradient(1200px 600px at 15% -10%, #F1EBDC 0%, transparent 60%),
    var(--paper);
  color:var(--ink);
  font-family:'Spectral', Georgia, serif;
  line-height:1.55;
  -webkit-font-smoothing:antialiased;
}
a{color:var(--khaki);}
.mono{font-family:'IBM Plex Mono', ui-monospace, monospace;}

/* ---------- header ---------- */
header.top{
  position:sticky; top:0; z-index:30;
  background:linear-gradient(180deg, var(--paper) 0%, var(--paper) 78%, transparent 100%);
  padding:22px 24px 14px;
  border-bottom:1px solid var(--rule);
}
.top-inner{max-width:920px; margin:0 auto;}
.eyebrow{
  font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:.16em; text-transform:uppercase;
  color:var(--ink-soft); display:flex; align-items:center; gap:10px; margin-bottom:6px;
}
.eyebrow .dot{width:5px;height:5px;border-radius:50%;background:var(--red);display:inline-block;}
h1{
  font-size:clamp(28px,4.2vw,40px); margin:0 0 4px; font-weight:700; letter-spacing:-.01em;
}
.subtitle{color:var(--ink-soft); font-size:15px; margin:0 0 16px; max-width:60ch;}

.controls{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}
#search{
  flex:1 1 260px; min-width:200px;
  font-family:'IBM Plex Mono'; font-size:13px;
  padding:11px 14px; border:1px solid var(--rule); border-radius:2px;
  background:var(--paper-card); color:var(--ink);
}
#search::placeholder{color:var(--ink-faint);}
#search:focus{outline:none; border-color:var(--khaki);}
.count{font-family:'IBM Plex Mono'; font-size:12px; color:var(--ink-soft); white-space:nowrap;}

.alpha-nav{display:flex; gap:6px; flex-wrap:wrap; margin-top:12px;}
.alpha-chip{
  font-family:'IBM Plex Mono'; font-size:12px; letter-spacing:.04em;
  border:1px solid var(--rule); background:var(--paper-card); color:var(--ink-soft);
  padding:5px 10px; border-radius:2px; cursor:pointer; user-select:none;
}
.alpha-chip:hover{border-color:var(--khaki); color:var(--khaki);}
.alpha-chip.dim{opacity:.35; pointer-events:none;}

.legend{
  max-width:920px; margin:14px auto 0; padding:0 0 2px;
  display:flex; gap:16px; flex-wrap:wrap;
  font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft);
}
.legend span{display:inline-flex; align-items:center; gap:6px;}
.legend i{width:10px;height:10px;border:1.5px solid currentColor;display:inline-block;}

/* ---------- layout ---------- */
main{max-width:920px; margin:0 auto; padding:28px 24px 90px;}
#empty{display:none; text-align:center; color:var(--ink-soft); font-family:'IBM Plex Mono'; font-size:13px; padding:60px 0;}

/* ---------- card ---------- */
.card{
  position:relative;
  background:var(--paper-card);
  border:1px solid var(--rule);
  box-shadow:var(--shadow);
  margin-bottom:22px;
  padding:26px 26px 20px 26px;
}
.card::before{ /* dashed perforation top edge */
  content:"";
  position:absolute; left:18px; right:18px; top:0;
  border-top:1px dashed var(--rule-soft);
}
.tab{
  position:absolute; top:14px; left:-1px;
  background:var(--khaki); color:var(--paper-card);
  font-family:'IBM Plex Mono'; font-size:11px; font-weight:600; letter-spacing:.05em;
  padding:3px 8px 3px 10px; border-radius:0 3px 3px 0;
}
.card-head{
  display:flex; justify-content:space-between; align-items:flex-start; gap:14px;
  margin-bottom:14px; padding-left:26px;
}
.card-num{
  font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-faint); letter-spacing:.05em;
}
.name{
  font-size:22px; font-weight:700; margin:2px 0 2px; letter-spacing:-.005em;
}
.name a{color:inherit; text-decoration:underline; text-decoration-color:var(--rule); text-underline-offset:3px;}
.alt{font-style:italic; color:var(--ink-soft); font-size:14px; margin:0 0 4px;}
.birth{
  font-family:'IBM Plex Mono'; font-size:12px; color:var(--ink-soft);
}
.stamps{display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;}
.stamp{
  font-family:'IBM Plex Mono'; font-size:10px; font-weight:600; letter-spacing:.09em; text-transform:uppercase;
  border:1.5px solid; padding:4px 8px; border-radius:2px; transform:rotate(-3deg);
  white-space:nowrap;
}
.stamp.mort{color:var(--red); border-color:var(--red);}
.stamp.evade{color:var(--khaki); border-color:var(--khaki);}
.stamp.naturalise{color:var(--blue); border-color:var(--blue); border-style:dashed;}
.stamp.doublon{color:var(--amber); border-color:var(--amber); border-style:dashed; transform:rotate(2deg);}

.sections{padding-left:26px; display:grid; gap:12px;}
.sec{display:grid; grid-template-columns:132px 1fr; gap:12px; align-items:start;}
.sec .label{
  font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.07em;
  color:var(--ink-soft); padding-top:2px;
}
.sec .body{font-size:14.5px;}
.sec .body ul{margin:0; padding-left:18px;}
.sec .body li{margin-bottom:3px;}
.sec .body p{margin:0;}
.sec.bio .body{color:var(--ink); font-style:italic;}
.sec.mort .label, .sec.mort .body{color:var(--red);}

.sources{
  margin-top:14px; padding:12px 0 0 26px; border-top:1px solid var(--rule-soft);
  font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-faint);
}
.sources .label{text-transform:uppercase; letter-spacing:.07em; margin-right:8px; color:var(--ink-soft);}

@media (max-width:600px){
  .sec{grid-template-columns:1fr;}
  .sec .label{padding-top:0;}
  .card-head{flex-direction:column;}
  .stamps{justify-content:flex-start;}
}

footer{
  max-width:920px; margin:0 auto; padding:0 24px 60px; text-align:center;
  font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-faint);
}
footer a{color:var(--ink-soft);}

.top-btn{
  position:fixed; right:22px; bottom:22px;
  font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:.05em;
  background:var(--khaki); color:var(--paper-card); border:none; padding:10px 14px;
  border-radius:2px; cursor:pointer; box-shadow:var(--shadow); opacity:0; pointer-events:none;
  transition:opacity .2s;
}
.top-btn.show{opacity:1; pointer-events:auto;}
</style>
</head>
